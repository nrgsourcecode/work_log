{
  "manifest_version": 3,
  "name": "Active URL Tracker",
  "version": "1.0",

  "permissions": [
    "tabs",
    "windows",
    "webNavigation"
  ],

  "host_permissions": [
    "http://127.0.0.1:*/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [{
    "matches": ["https://web.whatsapp.com/*"],
    "js": ["whatsapp_handler.js"],
    "run_at": "document_idle"
  }],

  "web_accessible_resources": [{
    "resources": ["config.json"],
    "matches": ["<all_urls>"]
  }]
}